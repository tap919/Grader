# Grader — copy to .env and fill in values
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000

# Required
JWT_SECRET=change-me-to-a-long-random-string
DATABASE_URL=postgresql://user:password@localhost:5432/grader

# GitHub OAuth (required for login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

# Optional: raises GitHub API rate limits for repo grading
GITHUB_TOKEN=

# Google Gemini (required for AI grading)
GEMINI_API_KEY=

# Stripe billing (optional in dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# JWT tuning (optional)
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=7d

# Email notifications (optional)
RESEND_API_KEY=
SCAN_NOTIFY_EMAIL=
SCAN_NOTIFY_FROM=Grader <onboarding@resend.dev>

# RepoRank integration (optional)
REPORANK_URL=

# Overlay 365 shared auth (optional — for cross-service calls)
OVERLAY_MASTER_KEY=
