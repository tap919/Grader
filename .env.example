# Environment variables for Grader SaaS
# Copy this to .env and fill in your actual values
# IMPORTANT: NEVER commit .env to version control!

# ============================================================================
# DATABASE (PostgreSQL via Supabase)
# ============================================================================
# Get from Supabase: Settings -> Database -> Connection String -> Transaction mode
# Format: postgresql://postgres.[PROJECT_ID]:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/grader

# ============================================================================
# AUTHENTICATION (GitHub OAuth)
# ============================================================================
# Create GitHub OAuth app at: https://github.com/settings/developers
# Settings -> OAuth Apps -> New OAuth App
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_CLIENT_ID=Iv1.abc123def456
GITHUB_CLIENT_SECRET=your_github_oauth_secret_here
# IMPORTANT: Set this to your FRONTEND_URL + /api/v1/auth/github/callback
# For Vercel + Railway setup, use the Vercel URL so cookies work on the frontend domain:
#   https://your-vercel-domain.vercel.app/api/v1/auth/github/callback
# For Railway-only setup, use the Railway URL:
#   https://your-railway-url.up.railway.app/api/v1/auth/github/callback
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

# ============================================================================
# JWT Secret (for signing tokens)
# ============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_secure_jwt_secret_here_minimum_32_characters

# ============================================================================
# AI/ML (Google Gemini)
# ============================================================================
# Get API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyD_your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ============================================================================
# PAYMENTS (Stripe)
# ============================================================================
# Get keys at: https://dashboard.stripe.com/apikeys
# Use test keys for development, live keys for production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
# Get webhook secret at: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ============================================================================
# EMAIL (Resend)
# ============================================================================
# Get API key at: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here
FROM_EMAIL=noreply@yourdomain.com

# ============================================================================
# URLS & DOMAINS
# ============================================================================
# Local development: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# For backend-only: Backend service URL
# Local: http://localhost:3000
# Production: https://api.yourdomain.com or https://your-railway-url.up.railway.app
BACKEND_URL=http://localhost:3000

# ============================================================================
# APPLICATION
# ============================================================================
# development | staging | production
NODE_ENV=development

# Server port (usually 3000 for development, set by platform in production)
PORT=3000

# ============================================================================
# SUPABASE (Optional - for Supabase-specific features)
# ============================================================================
# Get from Supabase: Settings -> API
SUPABASE_URL=https://[PROJECT_ID].supabase.co
SUPABASE_ANON_KEY=eyJhbGc... (public key, safe to expose in frontend)
# SUPABASE_SERVICE_KEY=eyJhbGc... (secret, backend only!)

# ============================================================================
# API LIMITS & RATE LIMITING
# ============================================================================
# Express rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
