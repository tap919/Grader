# Test environment — safe placeholder values for local test runs
# Fill DATABASE_URL with your real Supabase connection string before running tests locally
JWT_SECRET=test-jwt-secret-not-for-production
SESSION_SECRET=test-session-secret-not-for-production
GEMINI_API_KEY=test-gemini-key
GEMINI_MODEL=gemini-2.5-flash
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_test_placeholder
GITHUB_CLIENT_ID=test-github-client-id
GITHUB_CLIENT_SECRET=test-github-client-secret
GITHUB_TOKEN=test-github-token
# Replace with your Supabase connection string:
# postgresql://postgres:[password]@db.[ref].supabase.co:6543/postgres
DATABASE_URL=postgresql://postgres:placeholder@localhost:5432/grader_test
SKIP_SCHEMA_ON_BOOT=true
DB_POOL_MAX=2
NODE_ENV=test
FRONTEND_URL=http://localhost:3000
PORT=3001
